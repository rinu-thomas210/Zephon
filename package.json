{
  "name": "zephon",
  "version": "1.0.0",
  "description": "Cross-Platform Secure Local File Synchronization Desktop Application",
  "author": "R I N U",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "tar": "^7.5.16"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.zephon.app",
    "productName": "Zephon",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "msi"
      ],
      "icon": "icon.ico"
    },
    "msi": {
      "oneClick": false,
      "perMachine": true,
      "createDesktopShortcut": true
    }
  }
}
